#include <stdio.h>
#include <ctype.h>

#define MAX_LENGTH 100

int main() {
    char sentence[MAX_LENGTH];
    int i = 0;

    printf("Enter a sentence: ");
    fgets(sentence, MAX_LENGTH, stdin);

    printf("Sentence without blanks: ");

    while (sentence[i]) {
        if (!isspace(sentence[i])) {
            printf("%c", sentence[i]);
        }
        i++;
    }

    printf("\n");

    return 0;
}
